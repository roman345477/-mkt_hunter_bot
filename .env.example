# ──────────────────────────────────────────
#  Marktplaats Hunter — Environment Config
# ──────────────────────────────────────────

# Telegram Bot (required for alerts)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here   # your personal chat ID or group ID

# Public URL of your deployed service (used in Mini App button)
BASE_URL=https://your-app.railway.app

# Scraper interval in seconds (default: 45)
SCRAPE_INTERVAL=45

# Server port (Railway sets this automatically)
PORT=8000
